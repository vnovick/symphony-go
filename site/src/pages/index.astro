<main>

<!-- ===== 2. Hero ===== -->
<section class="hero">
  <div class="hero-glow"></div>
  <div class="container" style="display:flex; flex-direction:column; align-items:center; text-align:center; position:relative;">
    <div style="margin-bottom:28px; text-align:center;">
      <div class="logo-mark" style="font-size:clamp(36px, 6vw, 56px); letter-spacing:2px;"><span class="logo-iter">ITER</span><span class="logo-slash">//</span><span class="logo-vox">VOX</span></div>
      <div class="logo-sub" style="font-size:10px; letter-spacing:4px; margin-top:6px;">AGENT ORCHESTRATOR</div>
    </div>
    <div class="hero-badge">
      <span class="hero-badge-dot"></span>
      Open Source &middot;
      <a href={githubUrl} style="color:var(--accent-strong); text-decoration:none;" target="_blank" rel="noopener">&#9733; GitHub</a>
      &middot;
      <a href={`${githubUrl}/sponsors`} style="color:var(--danger); text-decoration:none;" target="_blank" rel="noopener">&#9829; Sponsor</a>
    </div>
    <h1>Your codebase's journey,<br />narrated by agents</h1>
    <p class="hero-sub" style="max-width:520px;">Orchestrate AI agents across issues, profiles, and machines. Full visibility from dispatch to PR.</p>
    <div class="hero-ctas" style="justify-content:center;">
      <a href="/getting-started/" class="btn btn-primary">Get Started &#8594;</a>
      <a href={githubUrl} class="btn btn-outline" target="_blank" rel="noopener">
